<!-- <!doctype html> -->
<head>
  <meta charset="utf-8">

  <meta name="google" content="notranslate">

  <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

  {{#stylesheets}}
  <link rel="stylesheet" href="/assets/{{.}}.css">
  {{/stylesheets}}
  <link rel="icon" type="image/png" href="/{{meta.favicon}}">

  <meta property="og:url" content="{{meta.url}}"/>
  <meta property="og:title" content="{{meta.title}}"/>

  {{#meta.image}}
  <meta property="og:image" content="{{meta.og_image_url}}" />
  {{/meta.image}}

  <meta property="og:site_name" content="{{meta.title}}"/>

  {{#meta.feed_atom}}
  <link rel="alternate" type="application/atom+xml" title="{{meta.title}} (Atom)" href="{{meta.feed_atom}}"/>
  {{/meta.feed_atom}}
  {{#meta.feed_rss}}
  <link rel="alternate" type="application/rss+xml" title="{{meta.title}} (RSS)" href="{{meta.feed_rss}}"/>
  {{/meta.feed_rss}}

  <link rel="alternate" hreflang="en-us"
                        href="{{meta.url}}" />

  <title>{{meta.title}}</title>
  <style title="search">body {}</style>

  {{{meta.raw}}}
</head>
