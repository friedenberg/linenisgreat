Options +FollowSymLinks -Indexes
RewriteEngine On

RewriteRule "^$" "object.php?tab=about&args=digastric/kitts" [L,PT,B]
RewriteRule "^(yoga|code|objects|notes|slides|cocktails|resume|meet)/?$" "$1.php"
RewriteRule "^(objects)/(.+)$" "object_with_metadata.php?tab=$1&args=$2" [L,PT,B]
RewriteRule "^(notes)/(.+)$" "object_with_metadata.php?tab=$1&args=$2" [L,PT,B]
RewriteRule "^(slides)/(.+)$" "object.php?tab=$1&template=slide&args=$2" [L,PT,B]
RewriteRule "^yoga/(.+)$" "yoga_object.php?args=$1" [L,PT,B]
RewriteCond %{HTTP_HOST} ^code\.linenisgreat\.com$
RewriteRule "^([\w.-]+)/info/refs$" "code_git_proxy.php?project=$1&endpoint=info/refs" [L,PT,B,QSA]
RewriteCond %{HTTP_HOST} ^code\.linenisgreat\.com$
RewriteRule "^([\w.-]+)/git-upload-pack$" "code_git_proxy.php?project=$1&endpoint=git-upload-pack" [L,PT,B]
RewriteRule "^code/([\w.-]+)/info/refs$" "code_git_proxy.php?project=$1&endpoint=info/refs" [L,PT,B,QSA]
RewriteRule "^code/([\w.-]+)/git-upload-pack$" "code_git_proxy.php?project=$1&endpoint=git-upload-pack" [L,PT,B]
RewriteRule "^code/([\w.-]+)(.+)?$" "code.php?project=$1&remainder=$2" [L,PT,B]

RewriteCond %{HTTP_HOST} ^code.linenisgreat.com$
RewriteRule ^/?(.*)$ https://linenisgreat.com/code/$1 [R=302,L]
